# Database
DATABASE_URL=postgresql+psycopg://usuario:password@localhost:5432/institute_db

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Security (manage with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=replace-with-a-safe-random-value

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# Environment (development, staging, production)
ENVIRONMENT=development

# Logs
LOG_LEVEL=INFO